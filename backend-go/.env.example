# Copy to .env if you use a dotenv loader; Go reads the environment directly.
# PORT overrides config/backend.yaml server.port (bound in config.Load).
PORT=3001

# Same resolution as backend-ts: SQLITE_PATH → backend-go/config/backend.yaml → ../store/app.sqlite
# SQLITE_PATH=/absolute/path/app.sqlite

# User session JWT (HS256, claim typ=user). Falls back to API_JWT_SECRET, then dev default.
# AUTH_JWT_SECRET=
# API_JWT_SECRET=

# Optional: serve built frontend (repo root relative paths also work)
# STATIC_DIR=
