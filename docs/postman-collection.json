{
  "info": {
    "name": "Tasks API (technical test)",
    "description": "Aligned with docs/api-spec.json. Set `baseUrl`. Call **Register** or **Login**, copy `token` into collection variable **`bearerToken`** for POST/PATCH/DELETE.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:3000/api"
    },
    {
      "key": "taskId",
      "value": "1"
    },
    {
      "key": "bearerToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"secret12\"\n}"
        },
        "url": "{{baseUrl}}/auth/register",
        "description": "2–32 char username: lowercase letters, digits, underscore. Password 6–128 chars. Paste response `token` into `bearerToken`."
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"secret12\"\n}"
        },
        "url": "{{baseUrl}}/auth/login",
        "description": "Paste response `token` into collection variable `bearerToken` for writes."
      }
    },
    {
      "name": "List tasks",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/tasks?page=1&limit=20"
      }
    },
    {
      "name": "Create task",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"From Postman\",\n  \"description\": \"optional\"\n}"
        },
        "url": "{{baseUrl}}/tasks"
      }
    },
    {
      "name": "Get task by id",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/tasks/{{taskId}}"
      }
    },
    {
      "name": "Patch task",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{bearerToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"completed\": true\n}"
        },
        "url": "{{baseUrl}}/tasks/{{taskId}}"
      }
    },
    {
      "name": "Delete task",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{bearerToken}}" }],
        "url": "{{baseUrl}}/tasks/{{taskId}}"
      }
    }
  ]
}
