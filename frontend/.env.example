# =============================================================================
# Frontend — copy to .env: cp .env.example .env
# =============================================================================

# Tasks API (this repo’s backend-ts)
# Dev: /api + Vite proxy
# Deploy example: http://your-server-ip:3000/api
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://127.0.0.1:3000

# Optional: static Bearer for tools (session token from Log in takes precedence)
# VITE_API_TOKEN=

# Blockchain demo: Polygon PoS mainnet
VITE_CHAIN_ID=137
# Polygon USDT (ERC-20)
VITE_CONTRACT_ADDRESS=0xc2132d05d31c914a87c6611c10748aeb04b58e8f

# RainbowKit / WalletConnect (free): https://cloud.reown.com — required for WalletConnect & many mobile wallets
# VITE_WALLETCONNECT_PROJECT_ID=
