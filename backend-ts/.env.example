# =============================================================================
# backend-ts — copy to .env: cp .env.example .env
# =============================================================================

PORT=3000

# Optional: comma-separated browser origins for CORS (overrides backend-ts/config/backend.yaml `cors.origins`).
# Example (Vite dev): CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# CORS_ORIGINS=

# SQLite file. Precedence: SQLITE_PATH → backend-ts/config/backend.yaml `database.path` → store/app.sqlite (monorepo root; shared with backend-go).
# See docs/BACKEND_SHARED_CONTRACT.md
# SQLITE_PATH=/absolute/or/relative/path/to/file.sqlite

# HS256 secret for user login/register JWTs (POST/PATCH/DELETE on /api/tasks). Falls back to API_JWT_SECRET if unset.
# AUTH_JWT_SECRET=
#
# Optional: serve a built frontend from this folder. If unset, backend-ts will
# auto-detect ../frontend-dist (deployment) or ../frontend/dist (local build).
# STATIC_DIR=

# --- Auth (see README “Authentication”) ---
# Default: no auth. Optional static Bearer (match frontend VITE_API_TOKEN):
# API_BEARER_TOKEN=
#
# Optional JWT (HS256). If API_JWT_SECRET is set, it takes precedence over API_BEARER_TOKEN.
# API_JWT_SECRET=
# API_JWT_ISSUER=
# API_JWT_AUDIENCE=
